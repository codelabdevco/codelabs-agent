# =============================================================================
# Agent Fleet — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# Anthropic API Key (shared across all OpenClaw instances)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# OpenClaw Gateway Tokens (one per instance — generate with: openssl rand -hex 32)
CLAW_1_TOKEN=
CLAW_2_TOKEN=
CLAW_3_TOKEN=
CLAW_4_TOKEN=
CLAW_5_TOKEN=
CLAW_6_TOKEN=

# n8n credentials
N8N_USER=admin
N8N_PASSWORD=
N8N_API_KEY=
N8N_WEBHOOK_URL=http://localhost:5678/

# Dashboard auth
# Default admin login: admin / admin (CHANGE IMMEDIATELY)
# Generate vault key: openssl rand -hex 32
VAULT_MASTER_KEY=
