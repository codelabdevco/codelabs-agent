{
  "$schema": "https://openclaw.ai/schema/config.json",
  "gateway": {
    "port": 3001,
    "bind": "0.0.0.0"
  },
  "agents": {
    "defaults": {
      "model": "anthropic:claude-sonnet-4-20250514",
      "thinking": true,
      "compaction": {
        "enabled": true,
        "maxTokens": 150000
      }
    },
    "list": [
      {
        "id": "sales-agent",
        "name": "Sales Assistant",
        "systemPrompt": "You are a sales assistant for a waterworks contracting business. You help with lead generation, client follow-up, and proposal drafting. Respond in Thai unless the user writes in English."
      }
    ]
  },
  "channels": {},
  "models": {
    "anthropic": {
      "provider": "anthropic",
      "models": ["claude-sonnet-4-20250514", "claude-haiku-4-5-20251001"]
    }
  }
}
